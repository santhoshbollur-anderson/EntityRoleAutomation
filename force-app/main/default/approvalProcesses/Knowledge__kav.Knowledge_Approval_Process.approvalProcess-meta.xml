<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Title</field>
        <field>Owner</field>
        <field>CreatedDate</field>
        <field>RecordType</field>
        <field>AssignedBy</field>
        <field>Stage__c</field>
        <field>ArticleNumber</field>
        <field>ArticleType</field>
        <field>PublishStatus</field>
        <field>ArticleCreatedDate</field>
        <field>View_Article__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>jbarkum@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>mlevy@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>ravi.ganti@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>roberto.flores@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>santhosh.bollur@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <approver>
                <name>tdiazmarin@andersonadvisors.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Step 1</label>
        <name>Step_1</name>
    </approvalStep>
    <emailTemplate>unfiled$public/Knowledge_Approval_Request_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Knowledge__kav.PublishStatus</field>
            <operation>equals</operation>
            <value>Draft</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Email_Notification_for_Approved_Article</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Published</name>
            <type>KnowledgePublish</type>
        </action>
        <action>
            <name>Update_Stage_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Email_Notification_for_Rejected_Article</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_Stage_to_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_Stage_to_In_Review</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Knowledge Approval Process</label>
    <processOrder>1</processOrder>
    <recallActions>
        <action>
            <name>Update_Stage_to_Recalled</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
