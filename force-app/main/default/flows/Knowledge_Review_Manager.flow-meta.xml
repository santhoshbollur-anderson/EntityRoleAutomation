    <recordUpdates>
        <name>Update_Article_To_Draft</name>
        <label>Update Article To Draft</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <connector>
            <targetReference>Get_Record_Type</targetReference>
        </connector>
        <inputReference>Get_Knowledge_Article</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Article_To_Review</name>
        <label>Update Article To Review</label>
        <locationX>50</locationX>
        <locationY>566</locationY>
        <connector>
            <targetReference>Get_Record_Type</targetReference>
        </connector>
        <inputReference>Get_Knowledge_Article</inputReference>
    </recordUpdates>
    <screens>
        <name>Recall_Confirmation_Screen</name>
        <label>Recall to Draft</label>
        <locationX>314</locationX>
        <locationY>350</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_False_Status</targetReference>
        </connector>
        <fields>
            <name>Txt_Recall_Message</name>
            <fieldText>&lt;p&gt;This record is currently locked for quality assurance evaluation. &lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Recalling the article will return it to a Draft state, enabling you to make further modifications as needed. 🔄&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <nextOrFinishButtonLabel>Recall</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>Submit_Confirmation_Screen</name>
        <label>Submit for Review</label>
        <locationX>50</locationX>
        <locationY>350</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_True_Status</targetReference>
        </connector>
        <fields>
            <name>Txt_Submit_Message</name>
            <fieldText>&lt;p&gt;This article is now prepared for formal assessment. &lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Submitting it will initiate the review process and temporarily lock the record to maintain data integrity. 📥&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <nextOrFinishButtonLabel>Submit</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Knowledge_Article</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>ttRecallBody</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
