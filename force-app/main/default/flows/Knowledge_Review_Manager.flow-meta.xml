            </value>
        </inputParameters>
        <inputParameters>
            <name>targetId</name>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </inputParameters>
        <nameSegment>customNotificationAction</nameSegment>
        <versionSegment>1</versionSegment>
    </actionCalls>
    <assignments>
        <name>Assign_False_Status</name>
        <label>Assign False Status</label>
        <locationX>314</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>Get_Knowledge_Article.In_Review__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varNotificationActionType</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Recall</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Article_To_Draft</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_Recipient_Ids</name>
        <label>Assign Recipient Ids</label>
        <locationX>270</locationX>
        <locationY>1430</locationY>
        <assignmentItems>
            <assignToReference>varRecipientIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Active_Users.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Active_Users</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_True_Status</name>
        <label>Assign True Status</label>
        <locationX>50</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>Get_Knowledge_Article.In_Review__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varNotificationActionType</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Submit</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Article_To_Review</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_User_Ids</name>
        <label>Assign User Ids</label>
        <locationX>270</locationX>
        <locationY>1106</locationY>
        <assignmentItems>
            <assignToReference>varUserIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Queue_Members.UserOrGroupId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Queue_Members</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_Current_Review_State</name>
        <label>Check Current Review State</label>
        <locationX>182</locationX>
        <locationY>242</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Draft_Needs_Submission</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Knowledge_Article.In_Review__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Submit_Confirmation_Screen</targetReference>
            </connector>
            <label>Is Draft (Needs Submission)</label>
        </rules>
        <rules>
            <name>Is_Locked_Needs_Recall</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Knowledge_Article.In_Review__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Recall_Confirmation_Screen</targetReference>
            </connector>
            <label>Is Locked (Needs Recall)</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Has_Recipients</name>
        <label>Check Has Recipients</label>
        <locationX>182</locationX>
        <locationY>1538</locationY>
        <defaultConnectorLabel>No Recipients</defaultConnectorLabel>
        <rules>
            <name>Has_Valid_Recipients</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varRecipientIds</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Custom_Notification</targetReference>
            </connector>
            <label>Has Valid Recipients</label>
        </rules>
    </decisions>
    <description>Professional manager for Knowledge Review lifecycle. Toggles review status and sends bell notifications to the Knowledge Reviewers queue.</description>
    <formulas>
        <name>fxRecordTypeName</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Get_Record_Type.Name}), &apos;Knowledge Article&apos;, {!Get_Record_Type.Name})</expression>
    </formulas>
    <formulas>
        <name>fxSelectedBody</name>
        <dataType>String</dataType>
        <expression>IF({!varNotificationActionType} == &apos;Submit&apos;, {!ttSubmitBody}, {!ttRecallBody})</expression>
    </formulas>
    <formulas>
        <name>fxSelectedTitle</name>
        <dataType>String</dataType>
        <expression>IF({!varNotificationActionType} == &apos;Submit&apos;, &apos;Knowledge Article Submitted for Review&apos;, &apos;Knowledge Article Recalled from Review&apos;)</expression>
    </formulas>
    <interviewLabel>Knowledge Review Manager {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Knowledge Review Manager</label>
    <loops>
        <name>Loop_Active_Users</name>
        <label>Loop Active Users</label>
        <locationX>182</locationX>
        <locationY>1322</locationY>
        <collectionReference>Get_Active_Users</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Recipient_Ids</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Check_Has_Recipients</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Queue_Members</name>
        <label>Loop Queue Members</label>
        <locationX>182</locationX>
        <locationY>998</locationY>
        <collectionReference>Get_Queue_Members</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_User_Ids</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Active_Users</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
